import pandas as pd
import numpy as np
import seaborn as sns
import matplotlib.pyplot as plt
import os
from sklearn.model_selection import train_test_split
from sklearn.preprocessing import StandardScaler
from sklearn.ensemble import RandomForestClassifier
from sklearn.metrics import classification_report ,confusion_matrix ,accuracy_score
import shap

print('step 1:load data...')

data_path = 'E:\Machine Learning Project\Condition Montoring Of Hydraulic Systems\data'

sensor_files = { 'PS1': 'PS1.txt', 'PS2': 'PS2.txt', 'PS3': 'PS3.txt',     'PS4': 'PS4.txt', 'PS5': 'PS5.txt', 'PS6': 'PS6.txt',
    'EPS1': 'EPS1.txt',
    'FS1': 'FS1.txt', 'FS2': 'FS2.txt',
    'TS1': 'TS1.txt', 'TS2': 'TS2.txt', 'TS3': 'TS3.txt', 'TS4': 'TS4.txt',
    'VS1': 'VS1.txt',
    'CE': 'CE.txt', 'CP': 'CP.txt', 'SE': 'SE.txt'
}

sensor_data = {}

for name , file_name in sensor_files.items() :
    file_path = os.path.join(data_path , file_name)
    sensor_data[name] = pd.read_csv(file_path ,sep='\t' ,header= None)
    print(f"load done {name} : {sensor_data[name].shape}")

profile_path = os.path.join(data_path ,'profile.txt')
labels = pd.read_csv(profile_path ,sep='\t' ,header=None)

labels.columns=['Cooler_Condition', 'Valve_Condition', 'Internal_Pump_Leakage', 'Hydraulic_Accumulator', 'Stable_Flag']

target_columns = ['Cooler_Condition', 'Valve_Condition', 'Internal_Pump_Leakage', 'Hydraulic_Accumulator']

print("\nLoad target data done:")
print(labels.head())
print("\nDistribution sample:")
print("Cooler Condition:\n", labels['Cooler_Condition'].value_counts())
print("\nValve Condition:\n", labels['Valve_Condition'].value_counts())
print("\nPump Leakage:\n", labels['Internal_Pump_Leakage'].value_counts())
print("\nHydraulic_Accumulator:\n", labels['Hydraulic_Accumulator'].value_counts())

print('\nStep 2: feature engineering...')

feature_df = pd.DataFrame()

for name ,df in sensor_data.items():
    feature_df[f'{name}_mean'] = df.mean(axis=1)
    feature_df[f'{name}_std'] = df.std(axis=1) 
    feature_df[f'{name}_max'] = df.max(axis=1)
    feature_df[f'{name}_min'] = df.min(axis=1)

print('feature done:',feature_df.shape)

models = {}

print("Start train data\n" + "="*45)

for target in target_columns:
    print(f"Trainig data for: {target}")
    
    y = labels[target]
    
    X_train, X_test, y_train, y_test = train_test_split(
        feature_df, y, test_size=0.2, random_state=42, stratify=y
    )
    
 
    rf = RandomForestClassifier(n_estimators=100, max_depth=10, random_state=42, n_jobs=-1)
    rf.fit(X_train, y_train)
    

    y_pred = rf.predict(X_test)
    acc = accuracy_score(y_test, y_pred)
    
    models[target] = rf
    
    print(f"Training done (Accuracy): {acc:.2%}")
    print(f"--- Report of:{target} ---")
    print(classification_report(y_test, y_pred))
    print("-" * 30)

for component, model in models.items():
    importances = model.feature_importances_
    indices = np.argsort(importances)[-10:]
    
    plt.figure(figsize=(10, 5))
    plt.title(f'Top 10 Features for: {component}')
    plt.barh(range(len(indices)), importances[indices], color='skyblue', align='center')
    plt.yticks(range(len(indices)), [feature_df.columns[i] for i in indices])
    plt.xlabel('Relative Importance')
    plt.show()

for component, model in models.items():
    explainer = shap.TreeExplainer(model)
    shap_values = explainer.shap_values(X_test,
    check_additivity=False)
    shap.summary_plot(shap_values, X_test,
    class_names=model.classes_)